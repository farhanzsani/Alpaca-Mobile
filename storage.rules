rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ============================================
    // Helper Functions
    // ============================================

    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the file is an allowed image type
    function isImageType() {
      return request.resource.contentType.matches('image/jpeg')
        || request.resource.contentType.matches('image/png')
        || request.resource.contentType.matches('image/webp');
    }

    // Check if the file size is within the 5MB limit
    function isUnderMaxSize() {
      return request.resource.size <= 5 * 1024 * 1024;
    }

    // ============================================
    // User Files
    // ============================================
    // Users can only upload to their own folder
    // Only the file owner can delete their files
    match /users/{userId}/{allPaths=**} {
      // Anyone authenticated can read user files
      allow read: if isAuthenticated();

      // Only the owner can upload to their own folder
      // Must be an image and under 5MB
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && isImageType()
        && isUnderMaxSize();

      // Only the owner can update their own files
      allow update: if isAuthenticated()
        && request.auth.uid == userId
        && isImageType()
        && isUnderMaxSize();

      // Only the owner can delete their own files
      allow delete: if isAuthenticated()
        && request.auth.uid == userId;
    }

    // ============================================
    // Product Images
    // ============================================
    // Anyone can read product images (public catalog)
    // Only authenticated users can upload, with image validation
    match /products/{userId}/{allPaths=**} {
      // Public read access for product images
      allow read: if true;

      // Only the owner can upload product images
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && isImageType()
        && isUnderMaxSize();

      // Only the owner can update their product images
      allow update: if isAuthenticated()
        && request.auth.uid == userId
        && isImageType()
        && isUnderMaxSize();

      // Only the owner can delete their product images
      allow delete: if isAuthenticated()
        && request.auth.uid == userId;
    }

    // ============================================
    // Business Images
    // ============================================
    // Anyone can read business images (public listing)
    // Only authenticated owners can upload
    match /business/{userId}/{allPaths=**} {
      // Public read access for business images
      allow read: if true;

      // Only the owner can upload business images
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && isImageType()
        && isUnderMaxSize();

      // Only the owner can update their business images
      allow update: if isAuthenticated()
        && request.auth.uid == userId
        && isImageType()
        && isUnderMaxSize();

      // Only the owner can delete their business images
      allow delete: if isAuthenticated()
        && request.auth.uid == userId;
    }

    // ============================================
    // Deny all other access by default
    // ============================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
