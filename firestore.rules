rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // Helper Functions
    // ============================================

    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the authenticated user is the document owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if the ownerId field matches the authenticated user
    function isResourceOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    // Check if the incoming ownerId matches the authenticated user
    function isIncomingOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.ownerId;
    }

    // Prevent changing the ownerId field after creation
    function ownerIdUnchanged() {
      return request.resource.data.ownerId == resource.data.ownerId;
    }

    // ============================================
    // Users Collection
    // ============================================
    // Users can only read and write their own document
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // ============================================
    // Inventory Collection
    // ============================================
    // Only owner_umkm can CRUD their own inventory items
    match /inventory/{itemId} {
      allow read: if isResourceOwner();
      allow create: if isIncomingOwner()
        && request.resource.data.keys().hasAll(['ownerId', 'name', 'quantity'])
        && request.resource.data.ownerId is string
        && request.resource.data.name is string;
      allow update: if isResourceOwner()
        && ownerIdUnchanged();
      allow delete: if isResourceOwner();
    }

    // ============================================
    // Transactions Collection
    // ============================================
    // Only owner_umkm can CRUD their own transactions
    match /transactions/{transactionId} {
      allow read: if isResourceOwner();
      allow create: if isIncomingOwner()
        && request.resource.data.keys().hasAll(['ownerId', 'amount', 'type', 'createdAt'])
        && request.resource.data.ownerId is string
        && request.resource.data.amount is number
        && request.resource.data.type is string;
      allow update: if isResourceOwner()
        && ownerIdUnchanged();
      allow delete: if isResourceOwner();
    }

    // ============================================
    // Media Collection
    // ============================================
    // Only authenticated users can create media entries
    // Only the uploader can update or delete their own media
    match /media/{mediaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['uploadedBy', 'url', 'createdAt'])
        && request.resource.data.uploadedBy == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.uploadedBy == request.auth.uid
        && request.resource.data.uploadedBy == resource.data.uploadedBy;
      allow delete: if isAuthenticated()
        && resource.data.uploadedBy == request.auth.uid;
    }

    // ============================================
    // Business Locations Collection
    // ============================================
    // Anyone can read business locations (public listing)
    // Only owner_umkm can create, update, and delete their own
    match /business_locations/{locationId} {
      allow read: if true;
      allow create: if isIncomingOwner()
        && request.resource.data.keys().hasAll(['ownerId', 'name', 'address'])
        && request.resource.data.ownerId is string
        && request.resource.data.name is string
        && request.resource.data.address is string;
      allow update: if isResourceOwner()
        && ownerIdUnchanged();
      allow delete: if isResourceOwner();
    }

    // ============================================
    // Products Collection
    // ============================================
    // Anyone can read products (public catalog)
    // Only owner_umkm can create, update, and delete their own
    match /products/{productId} {
      allow read: if true;
      allow create: if isIncomingOwner()
        && request.resource.data.keys().hasAll(['ownerId', 'name', 'price'])
        && request.resource.data.ownerId is string
        && request.resource.data.name is string
        && request.resource.data.price is number;
      allow update: if isResourceOwner()
        && ownerIdUnchanged();
      allow delete: if isResourceOwner();
    }

    // ============================================
    // Waste Resources Collection
    // ============================================
    // Only owner_umkm can CRUD their own waste resources
    match /waste_resources/{resourceId} {
      allow read: if isResourceOwner();
      allow create: if isIncomingOwner()
        && request.resource.data.keys().hasAll(['ownerId', 'name', 'type'])
        && request.resource.data.ownerId is string
        && request.resource.data.name is string
        && request.resource.data.type is string;
      allow update: if isResourceOwner()
        && ownerIdUnchanged();
      allow delete: if isResourceOwner();
    }

    // ============================================
    // Deny all other access by default
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
